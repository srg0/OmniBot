# Copy to .env in this directory (or set OMNIBOT_DATA_DIR and place .env there).
# Environment variables override values stored in hub_secrets.json via the Hub settings UI.

GEMINI_API_KEY=your_key_here

# Required for OpenStreetMap Nominatim (geocoding postal + country into lat/lng for Maps grounding).
# Use a stable app name + contact URL or email per https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_USER_AGENT=OmnibotHub/1.0 (your-contact-or-repo-url)

# Maps JavaScript API key: frontend contextual widget + fallback map image key.
# GOOGLE_MAPS_JS_API_KEY=your_maps_js_key

# Optional dedicated Static Maps key for backend map snapshots (if omitted, backend falls back to GOOGLE_MAPS_JS_API_KEY).
# GOOGLE_MAPS_STATIC_API_KEY=your_maps_static_key

# Optional: print Maps/location diagnostics to the backend terminal.
# OMNIBOT_MAPS_DEBUG=1

# Optional: semantic route decision logging (or inherits maps debug).
# OMNIBOT_ROUTE_DEBUG=1

# Optional: absolute path for bot_settings.json, known_bots.json, hub_secrets.json, etc. (default: directory containing app.py).
# OMNIBOT_DATA_DIR=
#
# Per-bot settings are stored in bot_settings.json (created at runtime). Empty file or missing file = code defaults.
# See bot_settings.json.example in this folder.

# Optional: bind address and port for uvicorn (defaults: 0.0.0.0, 8000).
# HOST=0.0.0.0
# PORT=8000

# Optional: serve a production Vite build from this directory (same origin as API). Used by Docker image.
# OMNIBOT_STATIC_ROOT=/app/backend/static
